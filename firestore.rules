rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All data access goes through the Express server (Firebase Admin SDK).
    // The Admin SDK bypasses these rules, so denying all client access here
    // forces every read/write through the authenticated server proxy.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
